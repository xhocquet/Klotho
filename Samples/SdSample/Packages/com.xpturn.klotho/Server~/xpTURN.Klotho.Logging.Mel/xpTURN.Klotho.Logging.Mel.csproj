<!--
  xpTURN.Klotho.Logging.Mel — server mirror of the Plugins~/Logging.Mel asmdef.
  Optional MEL interop adapter: bridges IKLogger to Microsoft.Extensions.Logging.
  The MEL package is consumer-provided in Unity (precompiled reference); this csproj
  pulls it from NuGet for the .NET server build.

  Optional: only reference this from a server csproj that wants MEL logging.
-->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <AssemblyName>xpTURN.Klotho.Logging.Mel</AssemblyName>
    <RootNamespace>xpTURN.Klotho.Logging.Mel</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\xpTURN.Klotho.Logging\xpTURN.Klotho.Logging.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)..\..\Plugins~\Logging.Mel\*.cs"
             Link="Logging.Mel\%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
