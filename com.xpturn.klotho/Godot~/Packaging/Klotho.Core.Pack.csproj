<!--
  NP1 — Core NuGet pack project (xpTURN.Klotho.Runtime).

  Dedicated packaging project: the in-repo Godot core csproj (../xpTURN.Klotho.Runtime.csproj)
  and the samples are left untouched. This project produces the redistributable core DLL package:
    - Same engine-agnostic core source (Runtime/**, Unity/** excluded) as the in-repo build.
    - Vendored LiteNetLib source (ThirdParty/LiteNetLib.v2.1.4/**) is EXCLUDED and replaced by the
      LiteNetLib 2.1.4 NuGet dependency (vendored copy is byte-identical to stock 2.1.4).
    - KlothoGenerator is referenced (for the core's own generated code) AND bundled as a NuGet analyzer
      so a consumer's own ECS components are generated by merely referencing this package.
    - EnableDynamicLoading=true so the assembly loads/unloads cleanly under the Godot editor.
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>xpTURN.Klotho.Runtime</AssemblyName>
    <RootNamespace>xpTURN.Klotho</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <IncludeBuildOutput>true</IncludeBuildOutput>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>xpTURN.Klotho.Runtime</PackageId>
    <Version>0.5.5</Version>
    <Authors>xpTURN</Authors>
    <Description>Engine-agnostic deterministic lockstep core for Klotho (Godot .NET build).</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>godot;deterministic;lockstep;netcode;ecs</PackageTags>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <PropertyGroup>
    <KlothoRuntimeRoot>$(MSBuildThisFileDirectory)..\..\Runtime</KlothoRuntimeRoot>
    <KlothoGenerator>$(MSBuildThisFileDirectory)..\..\Plugins\Analyzers\KlothoGenerator.dll</KlothoGenerator>
  </PropertyGroup>

  <!-- Source generator: used to build this core AND shipped to consumers as an analyzer. -->
  <ItemGroup>
    <Analyzer Include="$(KlothoGenerator)" />
    <None Include="$(KlothoGenerator)" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <!-- Runtime deps (LiteNetLib replaces the excluded vendored source). -->
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="LiteNetLib" Version="2.1.4" />
  </ItemGroup>

  <!-- Engine-agnostic core. Excludes Unity/** (engine-coupled) and the vendored LiteNetLib source
       (ThirdParty/LiteNetLib.v2.1.4/**) which the LiteNetLib NuGet package supplies instead. -->
  <ItemGroup>
    <Compile Include="$(KlothoRuntimeRoot)\**\*.cs"
             Exclude="$(KlothoRuntimeRoot)\Unity\**\*.cs;$(KlothoRuntimeRoot)\ThirdParty\LiteNetLib.v2.1.4\**\*.cs"
             Link="Runtime\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
