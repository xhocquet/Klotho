<!--
  KlothoServer.Core.props — Tier 1+2 shared source links.
  Imported via <Import> from each game-specific DedicatedServer.csproj.

  Why use .props (source sharing) instead of ProjectReference (binary reference):
  The source generator (KlothoGenerator) emits RegisterGeneratedTypes as a partial
  method on CommandFactory/MessageSerializer, so every [KlothoSerializable] type
  must live in a single compilation unit.
  Splitting via ProjectReference would force the partial class to cross assembly
  boundaries, leaving registration incomplete.
-->
<Project>
  <PropertyGroup>
    <KlothoRuntimeRoot>$(MSBuildThisFileDirectory)..\Runtime</KlothoRuntimeRoot>
    <KlothoLoggingRoot>$(MSBuildThisFileDirectory)..\Runtime\Logging</KlothoLoggingRoot>
    <KlothoLiteNetLibRoot>$(MSBuildThisFileDirectory)..\Runtime\ThirdParty\LiteNetLib.v2.1.4</KlothoLiteNetLibRoot>
    <KlothoTransportRoot>$(MSBuildThisFileDirectory)..\Runtime\LiteNetLib</KlothoTransportRoot>
    <KlothoGameplayRoot>$(MSBuildThisFileDirectory)..\Runtime\Gameplay</KlothoGameplayRoot>
  </PropertyGroup>

  <!-- Source Generator (prebuilt DLL shipped in package; rebuild via Tools/gen.build.sh in dev) -->
  <ItemGroup>
    <Analyzer Include="$(MSBuildThisFileDirectory)..\Plugins\Analyzers\KlothoGenerator.dll" />
  </ItemGroup>

  <!-- NuGet -->
  <ItemGroup>
    <PackageReference Include="K4os.Compression.LZ4" Version="1.3.8" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Runtime tree (engine-agnostic core + Logging + Gameplay + LiteNetLib transport + ThirdParty lib).
         Excludes: Unity/ (engine-coupled), Json/ (DataAsset.Json subtree). -->
    <Compile Include="$(KlothoRuntimeRoot)\**\*.cs"
             Exclude="$(KlothoRuntimeRoot)\Unity\**\*.cs;$(KlothoRuntimeRoot)\**\Json\**\*.cs"
             Link="Runtime\%(RecursiveDir)%(Filename)%(Extension)" />

    <!-- Server shared utilities (props-co-located helpers). -->
    <Compile Include="$(MSBuildThisFileDirectory)*.cs" Link="Server\%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
